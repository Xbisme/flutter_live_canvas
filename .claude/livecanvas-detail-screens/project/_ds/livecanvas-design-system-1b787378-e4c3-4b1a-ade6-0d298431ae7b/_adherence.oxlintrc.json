{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/controls/**",
              "components/feedback/**",
              "components/navigation/**",
              "components/wallpaper/**",
              "ui_kits/livecanvas_app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Clash Display|Satoshi|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Clash Display, Satoshi, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|icon|iconRight|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, icon, iconRight, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|aurora|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'aurora' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|actionLabel|onAction|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, description, actionLabel, onAction, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|active|icon|count|onClick|style|key|ref|className|style|children)$/]",
        "message": "<FilterChip> doesn't accept that prop. Declared props: label, active, icon, count, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|activeIcon|active|variant|size|label|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, activeIcon, active, variant, size, label, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:glass|solid|ghost)$/]",
        "message": "<IconButton> variant must be one of 'glass' | 'solid' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetaChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|icon|tone|live|style|key|ref|className|style|children)$/]",
        "message": "<MetaChip> doesn't accept that prop. Declared props: children, icon, tone, live, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetaChip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:glass|surface)$/]",
        "message": "<MetaChip> tone must be one of 'glass' | 'surface'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PremiumBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|label|style|key|ref|className|style|children)$/]",
        "message": "<PremiumBadge> doesn't accept that prop. Declared props: variant, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PremiumBadge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:tag|dot)$/]",
        "message": "<PremiumBadge> variant must be one of 'tag' | 'dot'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|icon|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, icon, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|wordmark|leading|trailing|transparent|style|key|ref|className|style|children)$/]",
        "message": "<TopBar> doesn't accept that prop. Declared props: title, wordmark, leading, trailing, transparent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WallpaperCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:preview|auraColor|title|author|premium|favorite|duration|live|width|onClick|onFavorite|style|key|ref|className|style|children)$/]",
        "message": "<WallpaperCard> doesn't accept that prop. Declared props: preview, auraColor, title, author, premium, favorite, duration, live, width, onClick, onFavorite, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
